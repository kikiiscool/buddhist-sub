# Frontend
NEXT_PUBLIC_API_BASE=https://api.example.com

# Backend
APP_ENV=production
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
REDIS_URL=redis://host:6379/0
# In production with >1 backend replica: keep 0 and run
# `alembic upgrade head` from an init container / CI step.
RUN_MIGRATIONS_ON_START=0
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_ACCESS_KEY=REPLACE_ME
S3_SECRET_KEY=REPLACE_ME
S3_BUCKET=buddhist-sub
DASHSCOPE_API_KEY=REPLACE_ME

# Worker
WHISPER_BACKEND=faster
CELERY_BROKER_URL=redis://host:6379/0
CELERY_RESULT_BACKEND=redis://host:6379/1
