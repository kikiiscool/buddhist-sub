# ============== Database ==============
POSTGRES_USER=buddhist
POSTGRES_PASSWORD=buddhist_dev_pw
POSTGRES_DB=buddhist_sub
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://buddhist:buddhist_dev_pw@localhost:5432/buddhist_sub

# ============== Redis ==============
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============== Object storage (MinIO local) ==============
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=buddhist-sub
S3_REGION=us-east-1

# ============== Whisper backend ==============
# Options: mlx | faster | openai
WHISPER_BACKEND=mlx
WHISPER_MODEL=large-v3
WHISPER_LANGUAGE=yue
# Path to text file containing initial_prompt (Buddhist hot-words)
WHISPER_INITIAL_PROMPT_FILE=./data/prompts/whisper_initial_cantonese.txt
# Only used when WHISPER_BACKEND=openai
OPENAI_API_KEY=

# ============== Qwen / DashScope ==============
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
QWEN_MODEL=qwen2.5-72b-instruct
QWEN_FALLBACK_MODEL=qwen2.5-14b-instruct
# International endpoint: https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# Mainland endpoint:      https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# ============== Embedding (for CBETA RAG) ==============
# Options: bge-m3 (local) | dashscope (text-embedding-v3)
EMBEDDING_BACKEND=dashscope
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_DIM=1024

# ============== App ==============
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_CORS_ORIGINS=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
